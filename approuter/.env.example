# Cloudflare — centralize here. Apps register via router and no longer need CF_TOKEN.
# Preferred: CF_TOKEN + CF_ACCOUNT_ID — API fetches tunnel token. Token needs Cloudflare Tunnel Write (or god mode).
#   CF_ACCOUNT_ID: Dashboard URL or API /accounts response. Zero Trust > Networks > Connectors shows account.
# Fallback: TUNNEL_TOKEN (eyJ... from dashboard) — copy from tunnel > Configure
CF_TOKEN=
CF_ACCOUNT_ID=
CF_TUNNEL_ID=b12525df-6971-4c47-9a0d-61ee57a5cbd5
TUNNEL_TOKEN=

# Cloudflared config (templated via env)
# CLOUDFLARED_CREDENTIALS=     # override credentials path
# CLOUDFLARED_TUNNEL_SERVICE=  # override ingress target (default: http://127.0.0.1:ROUTER_PORT)

# Approuter (optional overrides)
# ROUTER_PORT=8080
# ROUTER_BIND=127.0.0.1
# ROUTER_CONFIG_DIR=.

# start-all: ronin-sites needs SK or SECRET_KEY (or dev fallback used)
# SK=your-secret-key

# start-all: rogue-repo optional DATABASE_URL for auth (postgres)
# DATABASE_URL=postgres://user:pass@localhost:5432/rogue_repo

# oakilydokily — Google OAuth (Sign in) + Gmail (waiver emails)
# See oakilydokily/docs/GOOGLE_WORKSPACE_SETUP.md
# OD_BASE_URL=https://oakilydokily.com
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_APPLICATION_CREDENTIALS=/home/mcochran/.config/gcloud/oakilydokily-sa.json
# GMAIL_IMPERSONATE_USER=byrdkaylie34@gmail.com
# GMAIL_FROM=OakilyDokily <noreply@oakilydokily.com>
# RESEND_API_KEY=
# RESEND_FROM=OakilyDokily <noreply@oakilydokily.com>
