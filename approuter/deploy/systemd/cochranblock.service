[Unit]
Description=Cochranblock static site
After=approuter.service network.target
Requires=approuter.service

[Service]
Type=simple
WorkingDirectory=/home/mcochran/cochranblock
Environment=APPROUTER_URL=http://127.0.0.1:8080
Environment=ROUTER=http://127.0.0.1:8080
EnvironmentFile=/home/mcochran/cochranblock/approuter/.env
ExecStart=/home/mcochran/cochranblock/target/release/cochranblock
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
